generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  AUDITOR
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  BOOKED
  MAINTENANCE
  RETIRED
  LOST
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  UNUSABLE
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum BookingStatus {
  REQUESTED
  PENDING
  APPROVED
  ACTIVE
  REJECTED
  CANCELLED
  COMPLETED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  REQUESTED
  APPROVED
  REJECTED
  OPEN
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AuditResult {
  VERIFIED
  MISSING
  DAMAGED
  RETIRED
  UNREACHABLE
  MISPLACED
  NEEDS_REVIEW
}

enum AuditStatus {
  PLANNED
  ACTIVE
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum AuditDiscrepancyType {
  MISSING_ASSET
  DAMAGED_ASSET
  WRONG_LOCATION
  UNEXPECTED_ALLOCATION
  UNEXPECTED_DEPARTMENT
  UNKNOWN_ASSET_CONDITION
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         Role         @default(EMPLOYEE)
  departmentId String?      @map("department_id") @db.Uuid
  status       RecordStatus @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  department          Department?         @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments  Department[]        @relation("DepartmentManager")
  allocations         Allocation[]        @relation("AllocationUser")
  assignedAllocations Allocation[]        @relation("AllocationAssignedBy")
  requestedTransfers  Transfer[]          @relation("TransferRequestedBy")
  approvedTransfers   Transfer[]          @relation("TransferApprovedBy")
  fromTransfers       Transfer[]          @relation("TransferFromUser")
  toTransfers         Transfer[]          @relation("TransferToUser")
  requestedBookings   Booking[]           @relation("BookingRequestedBy")
  approvedBookings    Booking[]           @relation("BookingApprovedBy")
  reportedMaintenance MaintenanceTicket[] @relation("MaintenanceReportedBy")
  assignedMaintenance MaintenanceTicket[] @relation("MaintenanceAssignedTo")
  createdAssets       Asset[]             @relation("AssetCreatedBy")
  updatedAssets       Asset[]             @relation("AssetUpdatedBy")
  createdAudits       Audit[]             @relation("AuditCreatedBy")
  assignedAudits      Audit[]             @relation("AuditAssignedTo")
  auditRecords        AuditRecord[]       @relation("AuditRecordAuditor")
  auditLogs           AuditLog[]          @relation("AuditLogActor")
  notifications       Notification[]
  preference          UserPreference?

  @@index([role])
  @@index([departmentId])
  @@index([status])
  @@map("users")
}

model Department {
  id                 String       @id @default(uuid()) @db.Uuid
  name               String       @unique
  code               String       @unique
  managerId          String?      @map("manager_id") @db.Uuid
  parentDepartmentId String?      @map("parent_department_id") @db.Uuid
  status             RecordStatus @default(ACTIVE)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  manager          User?        @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  parentDepartment Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  childDepartments Department[] @relation("DepartmentHierarchy")
  users            User[]       @relation("DepartmentUsers")
  assets           Asset[]
  allocations      Allocation[]
  fromTransfers    Transfer[]   @relation("TransferFromDepartment")
  toTransfers      Transfer[]   @relation("TransferToDepartment")
  audits           Audit[]
  expectedAuditRecords AuditRecord[] @relation("AuditRecordExpectedDepartment")
  verifiedAuditRecords AuditRecord[] @relation("AuditRecordVerifiedDepartment")

  @@index([status])
  @@index([parentDepartmentId])
  @@map("departments")
}

model Category {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  code        String       @unique
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  assets Asset[]

  @@index([status])
  @@map("categories")
}

model Asset {
  id             String         @id @default(uuid()) @db.Uuid
  assetCode      String         @unique @map("asset_code")
  serialNumber   String?        @unique @map("serial_number")
  name           String
  description    String?
  categoryId     String         @map("category_id") @db.Uuid
  departmentId   String?        @map("department_id") @db.Uuid
  createdById    String?        @map("created_by_id") @db.Uuid
  updatedById    String?        @map("updated_by_id") @db.Uuid
  status         AssetStatus    @default(AVAILABLE)
  condition      AssetCondition @default(GOOD)
  location       String?
  purchaseValue  Decimal?       @map("purchase_value") @db.Decimal(12, 2)
  purchaseDate   DateTime?      @map("purchase_date")
  warrantyExpiry DateTime?      @map("warranty_expiry")
  isBookable     Boolean        @default(false) @map("is_bookable")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  category           Category            @relation(fields: [categoryId], references: [id])
  department         Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy          User?               @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?               @relation("AssetUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  allocations        Allocation[]
  transfers          Transfer[]
  bookings           Booking[]
  maintenanceTickets MaintenanceTicket[]
  auditRecords       AuditRecord[]
  auditDiscrepancies AuditDiscrepancy[]

  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([serialNumber])
  @@index([createdById])
  @@index([updatedById])
  @@index([isBookable])
  @@map("assets")
}

model Allocation {
  id              String           @id @default(uuid()) @db.Uuid
  assetId         String           @map("asset_id") @db.Uuid
  userId          String?          @map("user_id") @db.Uuid
  departmentId    String?          @map("department_id") @db.Uuid
  assignedById    String           @map("assigned_by_id") @db.Uuid
  sourceTransferId String?         @unique @map("source_transfer_id") @db.Uuid
  status          AllocationStatus @default(ACTIVE)
  assignedAt      DateTime         @default(now()) @map("assigned_at")
  returnedAt      DateTime?        @map("returned_at")
  returnCondition AssetCondition?  @map("return_condition")
  returnReason    String?          @map("return_reason")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  asset          Asset     @relation(fields: [assetId], references: [id])
  user           User?     @relation("AllocationUser", fields: [userId], references: [id], onDelete: SetNull)
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedBy     User      @relation("AllocationAssignedBy", fields: [assignedById], references: [id])
  sourceTransfer Transfer? @relation("TransferSourceAllocation", fields: [sourceTransferId], references: [id], onDelete: SetNull)

  @@index([assetId, status])
  @@index([userId, status])
  @@index([departmentId, status])
  @@index([assignedAt])
  @@index([returnedAt])
  @@map("allocations")
}

model Transfer {
  id               String         @id @default(uuid()) @db.Uuid
  assetId          String         @map("asset_id") @db.Uuid
  requestedById    String         @map("requested_by_id") @db.Uuid
  approvedById     String?        @map("approved_by_id") @db.Uuid
  fromUserId       String?        @map("from_user_id") @db.Uuid
  toUserId         String?        @map("to_user_id") @db.Uuid
  fromDepartmentId String?        @map("from_department_id") @db.Uuid
  toDepartmentId   String?        @map("to_department_id") @db.Uuid
  status           TransferStatus @default(PENDING)
  reason           String
  decisionNotes    String?        @map("decision_notes")
  requestedAt      DateTime       @default(now()) @map("requested_at")
  decidedAt        DateTime?      @map("decided_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  asset          Asset       @relation(fields: [assetId], references: [id])
  requestedBy    User        @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy     User?       @relation("TransferApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  fromUser       User?       @relation("TransferFromUser", fields: [fromUserId], references: [id], onDelete: SetNull)
  toUser         User?       @relation("TransferToUser", fields: [toUserId], references: [id], onDelete: SetNull)
  fromDepartment Department? @relation("TransferFromDepartment", fields: [fromDepartmentId], references: [id], onDelete: SetNull)
  toDepartment   Department? @relation("TransferToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)
  createdAllocation Allocation? @relation("TransferSourceAllocation")

  @@index([assetId, status])
  @@index([requestedById, status])
  @@index([status])
  @@map("transfers")
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  assetId       String        @map("asset_id") @db.Uuid
  requestedById String        @map("requested_by_id") @db.Uuid
  approvedById  String?       @map("approved_by_id") @db.Uuid
  startTime     DateTime      @map("start_time")
  endTime       DateTime      @map("end_time")
  status        BookingStatus @default(PENDING)
  purpose       String
  decisionNotes String?       @map("decision_notes")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  asset       Asset @relation(fields: [assetId], references: [id])
  requestedBy User  @relation("BookingRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User? @relation("BookingApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([assetId, status])
  @@index([assetId, startTime, endTime])
  @@index([requestedById, status])
  @@map("bookings")
}

model MaintenanceTicket {
  id               String              @id @default(uuid()) @db.Uuid
  assetId          String              @map("asset_id") @db.Uuid
  reportedById     String              @map("reported_by_id") @db.Uuid
  assignedToId     String?             @map("assigned_to_id") @db.Uuid
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(REQUESTED)
  issueSummary     String              @map("issue_summary")
  issueDescription String?             @map("issue_description")
  resolutionNotes  String?             @map("resolution_notes")
  resolutionCost   Decimal?            @map("resolution_cost") @db.Decimal(12, 2)
  reportedAt       DateTime            @default(now()) @map("reported_at")
  assignedAt       DateTime?           @map("assigned_at")
  startedAt        DateTime?           @map("started_at")
  resolvedAt       DateTime?           @map("resolved_at")
  closedAt         DateTime?           @map("closed_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  asset      Asset @relation(fields: [assetId], references: [id])
  reportedBy User  @relation("MaintenanceReportedBy", fields: [reportedById], references: [id])
  assignedTo User? @relation("MaintenanceAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([assetId, status])
  @@index([status, priority])
  @@index([reportedById])
  @@map("maintenance_tickets")
}

model Audit {
  id                String      @id @default(uuid()) @db.Uuid
  title             String
  description       String?
  departmentId      String?     @map("department_id") @db.Uuid
  createdById       String      @map("created_by_id") @db.Uuid
  assignedAuditorId String?     @map("assigned_auditor_id") @db.Uuid
  status            AuditStatus @default(PLANNED)
  plannedStart      DateTime?   @map("planned_start")
  plannedEnd        DateTime?   @map("planned_end")
  startedAt         DateTime?   @map("started_at")
  completedAt       DateTime?   @map("completed_at")
  closedAt          DateTime?   @map("closed_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  department    Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy     User               @relation("AuditCreatedBy", fields: [createdById], references: [id])
  assignedAuditor User?            @relation("AuditAssignedTo", fields: [assignedAuditorId], references: [id], onDelete: SetNull)
  records       AuditRecord[]
  discrepancies AuditDiscrepancy[]

  @@index([status])
  @@index([departmentId])
  @@index([createdById])
  @@index([assignedAuditorId])
  @@map("audits")
}

model AuditRecord {
  id                        String          @id @default(uuid()) @db.Uuid
  auditId                   String?         @map("audit_id") @db.Uuid
  assetId                   String          @map("asset_id") @db.Uuid
  auditorId                 String?         @map("auditor_id") @db.Uuid
  result                    AuditResult?
  remarks                   String?
  expectedLocation          String?         @map("expected_location")
  expectedDepartmentId      String?         @map("expected_department_id") @db.Uuid
  expectedCondition         AssetCondition? @map("expected_condition")
  expectedAllocationUserId  String?         @map("expected_allocation_user_id") @db.Uuid
  locationVerified          String?         @map("location_verified")
  departmentVerifiedId      String?         @map("department_verified_id") @db.Uuid
  conditionVerified         AssetCondition? @map("condition_verified")
  allocationUserVerifiedId  String?         @map("allocation_user_verified_id") @db.Uuid
  verifiedAt                DateTime?       @map("verified_at")
  auditedAt                 DateTime        @default(now()) @map("audited_at")
  createdAt                 DateTime        @default(now()) @map("created_at")
  updatedAt                 DateTime        @updatedAt @map("updated_at")

  audit                    Audit?             @relation(fields: [auditId], references: [id], onDelete: Cascade)
  asset                    Asset              @relation(fields: [assetId], references: [id])
  auditor                  User?              @relation("AuditRecordAuditor", fields: [auditorId], references: [id], onDelete: SetNull)
  expectedDepartment       Department?        @relation("AuditRecordExpectedDepartment", fields: [expectedDepartmentId], references: [id], onDelete: SetNull)
  departmentVerified       Department?        @relation("AuditRecordVerifiedDepartment", fields: [departmentVerifiedId], references: [id], onDelete: SetNull)
  discrepancies            AuditDiscrepancy[]

  @@unique([auditId, assetId])
  @@index([auditId])
  @@index([assetId, auditedAt])
  @@index([result])
  @@map("audit_records")
}

model AuditDiscrepancy {
  id            String               @id @default(uuid()) @db.Uuid
  auditId       String               @map("audit_id") @db.Uuid
  auditRecordId String?              @map("audit_record_id") @db.Uuid
  assetId       String               @map("asset_id") @db.Uuid
  type          AuditDiscrepancyType
  message       String
  severity      String               @default("warning")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  audit       Audit        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  auditRecord AuditRecord? @relation(fields: [auditRecordId], references: [id], onDelete: SetNull)
  asset       Asset        @relation(fields: [assetId], references: [id])

  @@index([auditId, type])
  @@index([auditRecordId])
  @@index([assetId])
  @@map("audit_discrepancies")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId])
  @@map("audit_logs")
}

model Notification {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  category          String   @default("SYSTEM")
  priority          String   @default("INFO")
  title             String
  message           String
  isRead            Boolean  @default(false) @map("is_read")
  readAt            DateTime? @map("read_at")
  relatedEntityType String?  @map("related_entity_type")
  relatedEntityId   String?  @map("related_entity_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([category, createdAt])
  @@index([priority, createdAt])
  @@map("notifications")
}

model SystemSetting {
  key         String   @id
  category    String
  value       Json
  updatedById String?  @map("updated_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_settings")
}

model UserPreference {
  id                      String   @id @default(uuid()) @db.Uuid
  userId                  String   @unique @map("user_id") @db.Uuid
  avatarUrl               String?  @map("avatar_url")
  displayName             String?  @map("display_name")
  theme                   String   @default("SYSTEM")
  timezone                String   @default("Asia/Kolkata")
  language                String   @default("en")
  notificationPreferences Json     @default("{}") @map("notification_preferences")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([theme])
  @@map("user_preferences")
}
